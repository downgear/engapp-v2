# Copy this file to .env and fill in real values:
#   cp .env.example .env

# --- Database ---
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Frontend (used in emails: "đăng nhập tại ...") ---
FRONTEND_URL=http://localhost:8080

# --- Email (Gmail example below) ---
# Bắt buộc để gửi mail đăng ký / mail từ admin (nếu thiếu 3 dòng SMTP_* thì mail sẽ bị bỏ qua)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Dùng port 587 → để false. Dùng port 465 → để true
SMTP_SECURE=false
SMTP_USER=luuchilap@gmail.com
# KHÔNG dùng mật khẩu Gmail thường — xem hướng dẫn App Password trong Backend/api/docs/SMTP-GMAIL.md
SMTP_PASS=your-16-char-app-password
# Tùy chọn: địa chỉ hiển thị "From" (mặc định = SMTP_USER)
SMTP_FROM=luuchilap@gmail.com

OPENAI_API_KEY=sk-...
